include "Common.fbs";

namespace TRPG.Protocol;

// 채팅쳤을 때
table ChatMessageRequest
{
    type:ChatType;
    to:ulong;                   // DB에 저장된 받는 사람 고유 ID
    message:string;             // 메시지 본문
}
table ChatMessageResponse
{
    message:string;
}

// 서버에서 보내는 메시지
table ChatMessageNotify
{
    type:ChatType;
    from:ulong;
    to:ulong;
    message:string;
    timestamp:long;
}

// 서버에 연결했을 때
table ConnectRequest
{
    reserved:ubyte = 0;
}
table ConnectResponse
{
    guid:ulong;
}