namespace net.protocol;

enum chat_type : byte
{
    to_client = 0,         // 다른 사용자에게
    to_server = 1          // 서버에게
}

// 채팅
table chat_recv
{
    type:chat_type;
    from_guid:ulong;                // 자기 고유 ID
    to_guid:ulong;                  // 받는 사람 고유 ID
    message:string;                 // 메시지 본문
    timestamp_ms:long;          // 전송 시간 (Server Unix timestamp in milliseconds)

}

// GUID
table guid_recv
{
    guid:ulong;
}